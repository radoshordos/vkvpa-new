# ------------------------------------------------------------------
# VKV Provozní aktiv – vzorová konfigurace. ZKOPÍRUJ na `.env` a vyplň.
# Skutečný .env NIKDY necommituj (viz .gitignore). Po úniku hesla rotuj.
# ------------------------------------------------------------------

APP_NAME="VKV Provozni Aktiv"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

DB_CONNECTION=mysql
DB_CHARSET=utf8mb4
# Lokální MySQL: 127.0.0.1 | Docker Compose: db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vkvpab
# POZOR: pro Docker Compose NESMÍ být "root" – MySQL image odmítne
# MYSQL_USER=root a kontejner se nespustí. Použij dedikovaného uživatele.
DB_USERNAME=vkvpa
DB_PASSWORD=secret
# Heslo roota MySQL (jen pro Docker; používá ho MYSQL_ROOT_PASSWORD).
DB_ROOT_PASSWORD=rootsecret

# --- Adminer (DB nástroj v public/adminer/) ---
# Vstupní skript kontejneru z těchto hodnot vygeneruje .htpasswd (bcrypt).
# Bez vyplnění OBOU je přístup k Adminer odepřen (fail-closed).
ADMINER_AUTH_USER=
ADMINER_AUTH_PASSWORD=

# --- Administrátor (seeduje se do tabulky users) ---
# Všechny tři proměnné jsou povinné pro spuštění AdminUserSeeder.
ADMIN_USER=Beda
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=

# --- Mail (Fáze 8 – Laravel Mail) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@vkvpa.cz"
MAIL_FROM_NAME="${APP_NAME}"

# Kontaktní e-mail a jméno vyhodnocovatele (nahrazuje file-based mail.inc).
CONTACT_MAIL=ok1vum@hamradio.cz
CONTACT_NAME="Míla OK1VUM"

# Maximální velikost nahrávaného EDI souboru v kilobajtech (výchozí: 500).
EDI_MAX_SIZE_KB=500

# Maximální počet řádků výsledkové listiny jednoho kola (výchozí: 1000).
LISTINA_MAX_ROWS=1000

# --- Session & Security ---
# V produkci nastav na true – cookie se přenáší pouze přes HTTPS.
SESSION_SECURE_COOKIE=true
# Šifrování session dat (doporučeno: true).
SESSION_ENCRYPT=true

# Hashování hesel uživatelů: argon2id (výchozí) | argon | bcrypt.
# Staré bcrypt hashe zůstávají platné a při přihlášení se přehašují.
HASH_DRIVER=argon2id

# --- Cache, Queue & Logging ---
# Cache v DB (tabulky cache + cache_locks) – nevyžaduje zapisovatelný
# storage/framework/cache, takže odpadají problémy s právy mezi CLI a web uživatelem.
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stack



