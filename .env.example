# ------------------------------------------------------------------
# VKV Provozní aktiv – vzorová konfigurace. ZKOPÍRUJ na `.env` a vyplň.
# Skutečný .env NIKDY necommituj (viz .gitignore). Po úniku hesla rotuj.
# ------------------------------------------------------------------

APP_NAME="VKV Provozni Aktiv"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

DB_CONNECTION=mysql
DB_CHARSET=utf8mb4
# Lokální MySQL: 127.0.0.1 | Docker Compose: db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digipa
DB_USERNAME=root
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# --- Administrátor (seeduje se do tabulky users) ---
# Heslo je povinné – bez něj nebude admin účet funkční.
ADMIN_USER=Beda
ADMIN_PASS=

# --- Mail (Fáze 8 – Laravel Mail) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@vkvpa.cz"
MAIL_FROM_NAME="${APP_NAME}"

# Kontaktní e-mail a jméno vyhodnocovatele (nahrazuje file-based mail.inc).
CONTACT_MAIL=ok1vum@hamradio.cz
CONTACT_NAME="Míla OK1VUM"

# Maximální velikost nahrávaného EDI souboru v kilobajtech (výchozí: 500).
EDI_MAX_SIZE_KB=500

# Maximální počet řádků výsledkové listiny jednoho kola (výchozí: 1000).
LISTINA_MAX_ROWS=1000

# --- Session & Security ---
# V produkci nastav na true – cookie se přenáší pouze přes HTTPS.
SESSION_SECURE_COOKIE=false

# --- Queue & Logging ---
QUEUE_CONNECTION=database
LOG_CHANNEL=stack



