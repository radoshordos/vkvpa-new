# ------------------------------------------------------------------
# VKV Provozní aktiv – vzorová konfigurace. ZKOPÍRUJ na `.env` a vyplň.
# Skutečný .env NIKDY necommituj (viz .gitignore). Po úniku hesla rotuj.
# ------------------------------------------------------------------

APP_NAME="VKV Provozni Aktiv"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

DB_CONNECTION=mysql
DB_CHARSET=utf8mb4
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digipa
DB_USERNAME=root
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# --- Administrátor (Fáze 4 – seeduje se do tabulky users) ---
# Nahrazuje hardcoded Beda/oK1dOz. Heslo se uloží hashované.
ADMIN_USER=Beda
ADMIN_PASS=

# --- Mail (Fáze 8 – Laravel Mail) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@vkvpa.cz"
MAIL_FROM_NAME="${APP_NAME}"

# Kontaktní e-mail vyhodnocovatele (nahrazuje file-based mail.inc).
CONTACT_MAIL=ok1vum@hamradio.cz



