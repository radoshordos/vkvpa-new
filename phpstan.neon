# PHPStan + Larastan (Laravel-aware statická analýza).
# Spuštění:  vendor/bin/phpstan analyse   (nebo: composer stan)
includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6

    paths:
        - app
        - routes
        - database/migrations
        - database/seeders
        - tests

    excludePaths:
        - database/source_sql/*

    ignoreErrors:
        # Ediline má sloupce s nestandardními názvy ('Mode-code', 'Received-WWL',
        # 'Sent QSO number'…), které nelze zapsat jako @property (nejsou to platné
        # PHP identifikátory). Přistupuje se k nim dynamicky: $line->{'Received-WWL'}.
        - identifier: property.notFound
          paths:
            - app/Models/Ediline.php
            - app/Services/Scoring/ScoringService.php
            - app/Http/Controllers/MapController.php
