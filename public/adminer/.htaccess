# Přístup k databázovému nástroji Adminer je chráněn dvěma SOUČASNĚ platnými
# podmínkami (RequireAll): platné HTTP Basic přihlášení A spojení z localhostu.
# Použita syntaxe Apache 2.4 (mod_authz_core/mod_authz_host) – nahrazuje
# zastaralé Order/Deny/Allow + Satisfy z Apache 2.2, které na běžícím serveru
# (php:8.x-apache = Apache 2.4) nemusí být bez mod_access_compat k dispozici.
#
# POZN.: AuthUserFile (.htpasswd) musí být na serveru vytvořen, jinak Basic
# auth selže (fail-closed). Pro vzdálený přístup z konkrétní IP nahraď
# „Require local" za „Require ip YOUR.IP.HERE".
AuthType Basic
AuthName "Database Admin"
AuthUserFile /var/www/html/.htpasswd

<RequireAll>
    Require valid-user
    Require local
</RequireAll>
