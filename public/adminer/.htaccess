# Přístup k databázovému nástroji Adminer je chráněn HTTP Basic autentizací
# (mod_authz_user, syntaxe Apache 2.4). Soubor .htpasswd vytváří vstupní skript
# kontejneru (docker/entrypoint.sh) z proměnných ADMINER_AUTH_USER /
# ADMINER_AUTH_PASSWORD a ukládá ho MIMO webroot (/etc/apache2/adminer.htpasswd),
# takže ho nelze stáhnout přes HTTP. Bez těchto proměnných .htpasswd neexistuje
# a Basic auth selže (fail-closed = přístup odepřen).
#
# POZN.: účinné jen na Apache s `AllowOverride All` (viz docker/vhost.conf,
# docker/apache/000-default.conf). Pod nginx nebo `php artisan serve` se
# .htaccess ignoruje – tam Adminer nenasazuj / neprovozuj na nedůvěryhodné síti.
AuthType Basic
AuthName "Database Admin"
AuthUserFile /etc/apache2/adminer.htpasswd

# Lokální vývoj (Docker na localhost) projde bez hesla – uvnitř kontejneru
# přicházejí požadavky z hosta přes docker bridge (172.16.0.0/12). Odjinud
# se vyžaduje heslo z .htpasswd.
#
# POZOR pro produkci: pokud by před Apache stála reverzní proxy s privátní
# IP z rozsahu 172.16.0.0/12, tato výjimka by autentizaci obešla – v takovém
# nasazení blok <RequireAny> nahraď prostým `Require valid-user`.
<RequireAny>
    Require ip 127.0.0.1 ::1 172.16.0.0/12
    Require valid-user
</RequireAny>

# Volitelné zpřísnění – vyžadovat heslo A SOUČASNĚ konkrétní zdrojovou IP/síť.
# (pozor: za reverzní proxy/Dockerem je zdrojová IP IP proxy):
# <RequireAll>
#     Require valid-user
#     Require ip 192.168.1.0/24
# </RequireAll>
